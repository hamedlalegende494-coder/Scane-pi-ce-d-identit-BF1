{
  "name": "scan-id",
  "version": "1.0.0",
  "description": "Scan-ID - Numérisation de pièces d'identité",
  "main": "main.js",
  "author": "Scan-ID",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.scanid.app",
    "productName": "Scan-ID",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "index.html",
      "icon.png"
    ],
    "win": {
      "target": "nsis",
      "icon": "icon.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "icon.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  }
}
